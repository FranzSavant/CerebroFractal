# Neo4j Configuration Template
# Copiar este archivo a .env y rellenar con tus credenciales
# NUNCA subir .env a GitHub (ya está en .gitignore)

NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxxx
NEO4J_PASSWORD=xxxxxxxxxxxxxxxx
NEO4J_DATABASE=neo4j

# Ruta a tu vault de Obsidian (donde están tus notas reales)
# Ejemplo Windows: VAULT_PATH=C:\Users\TuUsuario\Documents\ObsidianVault
# Ejemplo con espacios: VAULT_PATH=G:\Mi unidad\Vault Name
VAULT_PATH=/ruta/a/tu/obsidian/vault
